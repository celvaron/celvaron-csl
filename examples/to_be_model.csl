# to_be_model.csl
# TO-BE (future state) model for Veloxa — the planned state after a 12-month transformation.
# Read alongside as_is_model.csl to understand what is changing and why.
#
# changeType values:
#   "new"       — entity did not exist before
#   "enhanced"  — entity existed but is substantially improved
#   "retired"   — entity is being removed (noted in description)
#   (no annotation) — entity is unchanged from AS-IS

version: "1.0"
state: "to-be"
author: "CSL Examples"
description: "TO-BE model for Veloxa — target state after 12-month product and ops transformation"

# ── Company (unchanged) ────────────────────────────────────────────────────────

company Veloxa {
  industry: "HR Technology"
  size: "mid-market"
  stage: "growth"
  description: "HR platform for distributed teams: onboarding, payroll, and compliance"
  caseStudies: [SeriesAScaleup, GlobalEnterprisePayroll, ContractorFleetMigration]

  voice: {
    tone: "Clear and direct. We speak like experienced HR engineers, not salespeople. We lead with outcomes and back every claim with data."
    formality: "semi-formal"
    perspective: "we"
    language: "en"
    dos: [
      "Lead with outcomes and measurable impact",
      "Use concrete numbers: days, percentages, headcount",
      "Speak to HR leaders and engineering teams equally"
    ]
    donts: [
      "No HR buzzwords or empty aspirational language",
      "Never say \"seamless\" or \"best-in-class\"",
      "No passive voice"
    ]
    examplePhrases: [
      "We cut time-to-hire in a new country from 14 days to 3.",
      "Payroll runs across 40 jurisdictions with zero manual steps.",
      "Our clients reduce HR admin load by 80% within the first quarter."
    ]
  }
}

# ── Market (unchanged) ───────────────────────────────────────────────────────

market HRTechMarket {
  region: "Europe, North America"
  size: 32000000000
}

# ── Segments — one new segment added ──────────────────────────────────────────

segment RemoteFirstScaleups {
  description: "Series A-C companies with 50–300 remote-first employees across 3+ countries"
  size: 80000
  operatesIn: HRTechMarket
}

segment EnterpriseMultinational {
  description: "Large enterprises with 500+ employees distributed across 10+ jurisdictions"
  size: 8000
  operatesIn: HRTechMarket
}

segment FreelanceAndContractorPlatforms {
  description: "Platforms managing 50+ contractors across multiple countries with variable engagement models"
  size: 15000
  operatesIn: HRTechMarket
  changeType: "new"
}

# ── Outcomes — improved targets, new outcomes ──────────────────────────────────

outcome SimplifyGlobalOnboarding {
  description: "Reduce time to hire someone in a new country from weeks to days"
  type: "efficiency"
  measuredBy: TimeToHireNewCountry
}

outcome EnsurePayrollCompliance {
  description: "Achieve zero payroll compliance violations across all jurisdictions"
  type: "risk"
  measuredBy: ComplianceViolationRate
}

outcome ReduceHRAdminLoad {
  description: "Cut HR team's manual admin time by automating routine tasks including expenses"
  type: "efficiency"
  measuredBy: HRAdminHoursPerEmployee
  changeType: "enhanced"
}

outcome EnableContractorManagement {
  description: "Support full contractor lifecycle: onboarding, payments, compliance, and off-boarding"
  type: "growth"
  measuredBy: ContractorOnboardingTime
  changeType: "new"
}

outcome ImprovePeopleInsights {
  description: "Surface real-time HR analytics enabling proactive decision-making"
  type: "growth"
  measuredBy: ReportingAdoptionRate
  changeType: "new"
}

# ── Metrics — new targets and new metrics ─────────────────────────────────────

metric TimeToHireNewCountry {
  description: "Calendar days to complete all onboarding steps for an employee in a new country"
  unit: "days"
  target: 3
  baseline: 14
  frequency: "per-hire"
  changeType: "enhanced"
}

metric ComplianceViolationRate {
  description: "Number of compliance findings per payroll run across all jurisdictions"
  unit: "count"
  target: 0
  baseline: 2.3
  frequency: "monthly"
}

metric HRAdminHoursPerEmployee {
  description: "Average HR team admin hours per employee per month"
  unit: "hours"
  target: 0.3
  baseline: 1.8
  frequency: "monthly"
  changeType: "enhanced"
}

metric MonthlyChurnRate {
  description: "Percentage of MRR lost to churn in a given month"
  unit: "percent"
  target: 0.8
  baseline: 2.4
  frequency: "monthly"
  changeType: "enhanced"
}

metric NetPromoterScore {
  description: "NPS score from quarterly customer survey"
  unit: "score"
  target: 60
  baseline: 32
  frequency: "quarterly"
  changeType: "enhanced"
}

metric ContractorOnboardingTime {
  description: "Days to onboard a contractor from invite to first approved timesheet"
  unit: "days"
  target: 2
  baseline: 0
  frequency: "per-hire"
  changeType: "new"
}

metric ReportingAdoptionRate {
  description: "Percentage of customers with at least one custom dashboard view created"
  unit: "percent"
  target: 70
  baseline: 0
  frequency: "monthly"
  changeType: "new"
}

# ── Offerings — enhanced + new ─────────────────────────────────────────────────

offering GlobalOnboardingModule {
  description: "Guided onboarding for 60+ countries (up from 40) with AI-assisted contract generation"
  type: "saas"
  targets: [RemoteFirstScaleups, EnterpriseMultinational]
  delivers: SimplifyGlobalOnboarding
  changeType: "enhanced"
}

offering PayrollAndComplianceEngine {
  description: "Fully automated payroll processing across 40 jurisdictions — zero manual review steps"
  type: "saas"
  targets: [RemoteFirstScaleups, EnterpriseMultinational]
  delivers: EnsurePayrollCompliance
  changeType: "enhanced"
}

offering HRSelfServicePortal {
  description: "Full-featured employee portal with leave, expenses, payslips, documents, and manager approvals"
  type: "saas"
  targets: [RemoteFirstScaleups, EnterpriseMultinational]
  delivers: ReduceHRAdminLoad
  changeType: "enhanced"
}

offering ContractorWorkerPlatform {
  description: "Dedicated product line for managing contractor and freelancer workforces globally"
  type: "saas"
  targets: FreelanceAndContractorPlatforms
  delivers: EnableContractorManagement
  changeType: "new"
}

offering AnalyticsAndInsightsSuite {
  description: "Real-time HR analytics with custom dashboards, benchmarks, and predictive attrition scores"
  type: "saas"
  targets: [RemoteFirstScaleups, EnterpriseMultinational]
  delivers: ImprovePeopleInsights
  changeType: "new"
}

# ── Packages — restructured pricing ───────────────────────────────────────────

package GrowthPlan {
  tier: "entry"
  price: 9
  billingCycle: "monthly"
  currency: "USD"
  description: "Per employee/month — new entry tier for companies under 100 employees"
  partOf: GlobalOnboardingModule
  features: [
    "Onboarding workflows for 60+ countries",
    "AI contract generation",
    "Employee self-service: leave and documents",
    "Chat support"
  ]
  changeType: "new"
}

package ScaleupPlan {
  tier: "standard"
  price: 15
  billingCycle: "monthly"
  currency: "USD"
  description: "Per employee/month — replaces legacy ScaleupPlan with expanded features"
  partOf: [GlobalOnboardingModule, HRSelfServicePortal]
  features: [
    "All Growth features",
    "Full expense management",
    "Payroll in 40 countries",
    "Analytics starter dashboard",
    "Priority email and chat support"
  ]
  changeType: "enhanced"
}

package EnterprisePlan {
  tier: "premium"
  price: 0
  billingCycle: "annual"
  currency: "USD"
  description: "Custom pricing — expanded to include Contractor Platform and Advanced Analytics"
  partOf: [PayrollAndComplianceEngine, AnalyticsAndInsightsSuite]
  features: [
    "All ScaleupPlan features",
    "Contractor workforce management",
    "Custom analytics and benchmarks",
    "Dedicated CSM and compliance advisor",
    "SSO / SAML",
    "SLA 99.95%",
    "Custom API integrations"
  ]
  changeType: "enhanced"
}

package ContractorBasicPlan {
  tier: "entry"
  price: 6
  billingCycle: "monthly"
  currency: "USD"
  description: "Per contractor/month on the new Contractor Workforce Platform"
  partOf: ContractorWorkerPlatform
  features: [
    "Contractor onboarding in 30+ countries",
    "Timesheet and approval workflows",
    "Payment disbursement",
    "Compliance checks"
  ]
  changeType: "new"
}

# ── Capabilities — maturity improvements and new additions ─────────────────────

capability OnboardingWorkflowEngine {
  description: "Configurable workflow engine covering 60+ countries — fully automated with no manual steps"
  maturityLevel: "optimised"
  supports: GlobalOnboardingModule
  changeType: "enhanced"
}

capability AIContractGeneration {
  description: "LLM-powered generation of jurisdiction-specific employment contracts from role and compensation data"
  maturityLevel: "scaling"
  supports: GlobalOnboardingModule
  dependsOn: OnboardingWorkflowEngine
  changeType: "new"
}

capability PayrollProcessingCore {
  description: "Automated payroll covering 40 jurisdictions — all previously manual jurisdictions now natively supported"
  maturityLevel: "optimised"
  supports: [PayrollAndComplianceEngine, ContractorWorkerPlatform]
  changeType: "enhanced"
}

capability ComplianceMonitoring {
  description: "Real-time compliance checking with auto-resolution for known violation types"
  maturityLevel: "operational"
  supports: PayrollAndComplianceEngine
  dependsOn: PayrollProcessingCore
  changeType: "enhanced"
}

capability EmployeeSelfService {
  description: "Full self-service for leave, expenses, payslips, documents — zero HR manual steps"
  maturityLevel: "optimised"
  supports: HRSelfServicePortal
  changeType: "enhanced"
}

capability ReportingAndInsights {
  description: "Real-time dashboards, custom report builder, and predictive attrition analytics"
  maturityLevel: "operational"
  supports: [GlobalOnboardingModule, PayrollAndComplianceEngine, AnalyticsAndInsightsSuite]
  changeType: "enhanced"
}

capability ContractorLifecycleManagement {
  description: "End-to-end contractor management: onboarding, time tracking, payments, compliance, off-boarding"
  maturityLevel: "developing"
  supports: ContractorWorkerPlatform
  dependsOn: [PayrollProcessingCore, ComplianceMonitoring]
  changeType: "new"
}

# ── Systems — legacy replaced ──────────────────────────────────────────────────

system VeloxaMicroservicesAPI {
  description: "Modular microservices API replacing the legacy monolith — each domain independently deployable"
  type: "internal"
  uses: [OnboardingWorkflowEngine, PayrollProcessingCore, ComplianceMonitoring, ReportingAndInsights]
  changeType: "new"
}

system SmartDocumentStore {
  description: "New document management system with full-text search, versioning, and automated tagging"
  type: "internal"
  uses: AIContractGeneration
  changeType: "new"
}

system AnalyticsPlatform {
  description: "Snowflake-based data warehouse with dbt transformations feeding the Analytics Suite"
  type: "internal"
  uses: ReportingAndInsights
  changeType: "new"
}

system StripePayments {
  description: "Payment disbursement for contractor payments in 30+ currencies"
  type: "external"
  uses: ContractorLifecycleManagement
  changeType: "new"
}

# LegacyDocumentStore — retired; replaced by SmartDocumentStore
# ExternalPayrollPartners — retired; all jurisdictions now natively supported
# VeloxaCoreAPI (monolith) — retired; replaced by VeloxaMicroservicesAPI

# ── Teams — restructured ───────────────────────────────────────────────────────

team PlatformEngineering {
  size: 30
  description: "Owns the microservices platform — evolved from CoreEngineering with 8 new hires"
  ownedBy: Veloxa
  owns: [OnboardingWorkflowEngine, PayrollProcessingCore, ComplianceMonitoring]
  changeType: "enhanced"
}

team AIAndAutomation {
  size: 6
  description: "New team dedicated to AI contract generation and intelligent compliance resolution"
  ownedBy: Veloxa
  owns: AIContractGeneration
  changeType: "new"
}

team ContractorProducts {
  size: 8
  description: "New product team owning the entire Contractor Workforce Platform"
  ownedBy: Veloxa
  owns: ContractorLifecycleManagement
  changeType: "new"
}

team HROperations {
  size: 4
  description: "Reduced from 8 to 4 — strategic ops only; automated workflows handle routine tasks"
  ownedBy: Veloxa
  owns: EmployeeSelfService
  changeType: "enhanced"
}

team ProductAndDesign {
  size: 10
  description: "Expanded product team covering Analytics Suite, Contractor Platform, and AI features"
  ownedBy: Veloxa
  changeType: "enhanced"
}

team CustomerSuccess {
  size: 14
  description: "New dedicated CS function split from support — owns onboarding and retention"
  ownedBy: Veloxa
  changeType: "new"
}

team CustomerSupport {
  size: 6
  description: "Reduced from 10 to 6 — AI deflection and self-service reduce ticket volume by 50%"
  ownedBy: Veloxa
  changeType: "enhanced"
}

team DataEngineering {
  size: 5
  description: "New team owning the Analytics Platform and data pipelines"
  ownedBy: Veloxa
  owns: ReportingAndInsights
  changeType: "new"
}

# ── Process — transformed ──────────────────────────────────────────────────────

process MonthlyPayrollRun {
  description: "Fully automated payroll execution — reduced from 3 days to 4 hours"
  ownedBy: HROperations
  measuredBy: ComplianceViolationRate
  changeType: "enhanced"
}

step CollectPayrollInputs {
  description: "Automated aggregation of timesheets, expenses, and contract changes — no manual steps"
  order: 1
  partOf: MonthlyPayrollRun
  changeType: "enhanced"
}

step RunPayrollCalculation {
  description: "Execute automated payroll calculation with real-time compliance validation"
  order: 2
  partOf: MonthlyPayrollRun
  dependsOn: CollectPayrollInputs
}

step AutomatedComplianceResolution {
  description: "Auto-resolve known compliance patterns; flag only novel exceptions for review"
  order: 3
  partOf: MonthlyPayrollRun
  dependsOn: RunPayrollCalculation
  changeType: "new"
}

step PayslipDistribution {
  description: "Payslips published directly to employee self-service portal — no email distribution"
  order: 4
  partOf: MonthlyPayrollRun
  dependsOn: AutomatedComplianceResolution
  changeType: "enhanced"
}

# ManualComplianceReview step — retired (replaced by AutomatedComplianceResolution)
# PartnerPayrollSubmission step — retired (all jurisdictions now natively processed)

# ── Objectives — updated ───────────────────────────────────────────────────────

objective ImproveRetentionAndNPS {
  description: "Drive churn below 1% and NPS above 55 through product quality improvements"
  timeframe: "Q1–Q4 2025"
  measuredBy: [MonthlyChurnRate, NetPromoterScore]
  achievedThrough: [HRSelfServicePortal, AnalyticsAndInsightsSuite]
  changeType: "enhanced"
}

objective ScaleContractorRevenue {
  description: "Launch Contractor Platform and reach $3M ARR within 12 months"
  timeframe: "Q2 2025–Q1 2026"
  measuredBy: ContractorOnboardingTime
  achievedThrough: ContractorWorkerPlatform
  changeType: "new"
}

# ── Case Studies ——————————————————————————————————————————————————

caseStudy SeriesAScaleup {
  client: "Northlight Labs"
  industry: "FinTech"
  challenge: "Hiring in 8 new countries simultaneously while keeping a 3-person HR team — onboarding took 3–4 weeks per country"
  solution: "Deployed GlobalOnboardingModule and HRSelfServicePortal across all 8 jurisdictions; migrated payroll from 3 separate local providers to the Payroll & Compliance Engine"
  outcome: "Time-to-hire in a new country dropped from 22 days to 3; HR team scaled from 3 to 5 while headcount grew 4×"
  technologies: ["GlobalOnboardingModule", "PayrollAndComplianceEngine", "HRSelfServicePortal"]
}

caseStudy GlobalEnterprisePayroll {
  client: "Meridian Manufacturing Group"
  industry: "Manufacturing & Industrial"
  challenge: "Running payroll across 12 European jurisdictions using a patchwork of local vendors and spreadsheets, resulting in 4–5 compliance findings per month"
  solution: "Migrated all 12 jurisdictions to the Payroll & Compliance Engine with automated compliance resolution; introduced the Analytics Suite for real-time payroll dashboards"
  outcome: "Compliance violations dropped to zero within 2 months; payroll cycle reduced from 3 days to 4 hours"
  technologies: ["PayrollAndComplianceEngine", "AnalyticsAndInsightsSuite", "VeloxaMicroservicesAPI"]
}

caseStudy ContractorFleetMigration {
  client: "Stackflow Platforms"
  industry: "Developer Tooling / SaaS"
  challenge: "Managing 200+ contractors across 18 countries with no unified system — payments delayed, compliance gaps in 6 jurisdictions"
  solution: "Deployed ContractorWorkerPlatform for onboarding, time tracking, and payment disbursement; integrated Stripe for multi-currency payouts"
  outcome: "Contractor onboarding reduced from 12 days to 2; payment delays eliminated; compliance gaps resolved in all 18 jurisdictions"
  technologies: ["ContractorWorkerPlatform", "StripePayments", "ComplianceMonitoring"]
}
