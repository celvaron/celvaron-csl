# advanced_model.csl
# Full-featured CSL model demonstrating all 16 entity types, all major relationships,
# multi-tier packaging, processes with steps, journeys, and objectives with metrics.
# Company: Nexara — a B2B SaaS company serving mid-market professional services firms.

version: "1.0"
author: "CSL Examples"
description: "Full advanced CSL model — all entity types and relationship patterns"

# ── Company ────────────────────────────────────────────────────────────────────

company Nexara {
  industry: "Professional Services Software"
  size: "scale-up"
  stage: "growth"
  description: "B2B SaaS platform for project-based professional services firms"
}

# ── Markets ────────────────────────────────────────────────────────────────────

market ProfessionalServicesMarket {
  region: "North America, Europe"
  size: 18000000000
  description: "Software for consulting, legal, accounting, and engineering firms"
}

market MidMarketSegment {
  region: "North America"
  size: 6000000000
  description: "Mid-market subset of professional services software"
}

# ── Customer Segments ──────────────────────────────────────────────────────────

segment MidMarketConsultingFirms {
  description: "Consulting firms with 50–500 employees running complex multi-project engagements"
  size: 45000
  operatesIn: ProfessionalServicesMarket
}

segment LegalAndAccountingFirms {
  description: "Legal and accounting firms that need matter-based time and billing"
  size: 30000
  operatesIn: ProfessionalServicesMarket
}

segment FreelancerNetworks {
  description: "Platforms managing 100+ independent consultants with variable billing"
  size: 12000
  operatesIn: MidMarketSegment
}

# ── Outcomes ───────────────────────────────────────────────────────────────────

outcome ImproveProjectProfitability {
  description: "Increase project gross margin by identifying scope creep and non-billable work early"
  type: "financial"
  measuredBy: ProjectGrossMargin
}

outcome ReduceRevenueLeakage {
  description: "Capture all billable hours and eliminate unbilled work"
  type: "efficiency"
  measuredBy: BillableUtilisationRate
}

outcome ShortenInvoiceCycle {
  description: "Reduce time from project completion to paid invoice"
  type: "efficiency"
  measuredBy: DaysSalesOutstanding
}

outcome IncreaseClientRetention {
  description: "Improve client satisfaction and reduce churn through transparent delivery"
  type: "growth"
  measuredBy: NetRevenueRetention
}

# ── Metrics ────────────────────────────────────────────────────────────────────

metric ProjectGrossMargin {
  description: "Revenue minus direct project costs, expressed as a percentage"
  unit: "percent"
  target: 55
  baseline: 42
  frequency: "monthly"
}

metric BillableUtilisationRate {
  description: "Percentage of logged hours that are billed to clients"
  unit: "percent"
  target: 85
  baseline: 71
  frequency: "monthly"
}

metric DaysSalesOutstanding {
  description: "Average number of days between project close and payment receipt"
  unit: "days"
  target: 21
  baseline: 38
  frequency: "monthly"
}

metric NetRevenueRetention {
  description: "Retained + expansion revenue divided by prior period revenue"
  unit: "percent"
  target: 115
  baseline: 102
  frequency: "quarterly"
}

metric TimeToOnboard {
  description: "Days from contract signed to first live project in Nexara"
  unit: "days"
  target: 7
  baseline: 21
  frequency: "monthly"
}

# ── Objectives ─────────────────────────────────────────────────────────────────

objective GrowAnnualRecurringRevenue {
  description: "Reach $30M ARR by end of fiscal year"
  timeframe: "FY2025"
  measuredBy: [NetRevenueRetention, BillableUtilisationRate]
  achievedThrough: [ProjectIntelligencePlatform, ClientPortal]
}

objective ReduceChurnBelow5Percent {
  description: "Reduce annual gross churn below 5%"
  timeframe: "FY2025"
  measuredBy: NetRevenueRetention
  achievedThrough: ClientPortal
}

# ── Offerings ──────────────────────────────────────────────────────────────────

offering ProjectIntelligencePlatform {
  description: "Core project management, time-tracking, and profitability analytics platform"
  targets: MidMarketConsultingFirms
  requires: [TimeAndExpenseCapture, ProjectProfitabilityEngine, InvoicingAndBilling]
  delivers: [ImproveProjectProfitability, ReduceRevenueLeakage]
  economics: {
    avgDealSize: 15000
    targetMargin: 0.72
  }
}

offering ClientPortal {
  description: "Self-service portal for end clients to view project status, approve deliverables, and pay invoices"
  targets: [MidMarketConsultingFirms, LegalAndAccountingFirms]
  requires: [ClientCollaborationHub, InvoicingAndBilling]
  delivers: [ShortenInvoiceCycle, IncreaseClientRetention]
  economics: {
    avgDealSize: 8000
    targetMargin: 0.68
  }
}

offering FreelancerEdition {
  description: "Lightweight version optimised for managing distributed freelancer networks"
  targets: FreelancerNetworks
  requires: [TimeAndExpenseCapture, IntegrationLayer]
  delivers: [ReduceRevenueLeakage, ShortenInvoiceCycle]
  economics: {
    avgDealSize: 5000
    targetMargin: 0.65
  }
}

# ── Packages ───────────────────────────────────────────────────────────────────

package Essentials {
  tier: "entry"
  position: 1
  offering: ProjectIntelligencePlatform
  description: "Entry-level plan for small consulting teams with up to 10 users"
  pricing: {
    model: "tiered_subscription"
    basePrice: 49
    currency: "USD"
    paymentTerms: "monthly"
  }
  includes: [
    "Unlimited projects",
    "Time tracking",
    "Basic invoicing",
    "Standard reports",
    "Email support",
    "Up to 10 users"
  ]
}

package Professional {
  tier: "standard"
  position: 2
  offering: ProjectIntelligencePlatform
  description: "For growing firms requiring profitability analytics and client-facing features"
  pricing: {
    model: "tiered_subscription"
    basePrice: 129
    currency: "USD"
    paymentTerms: "monthly"
  }
  includes: [
    "All Essentials features",
    "Profitability analytics",
    "Budget vs. actuals",
    "Client portal access",
    "Integrations: Xero, QuickBooks",
    "Priority support",
    "Up to 50 users"
  ]
}

package Enterprise {
  tier: "enterprise"
  position: 3
  offering: ProjectIntelligencePlatform
  description: "For large firms needing unlimited users, SSO, a dedicated CSM, and custom integrations"
  // Custom pricing — contact sales. basePrice is a placeholder minimum.
  pricing: {
    model: "usage_based"
    basePrice: 1
    currency: "USD"
    paymentTerms: "annual, custom quote"
  }
  includes: [
    "All Professional features",
    "Unlimited users",
    "Custom roles and permissions",
    "SSO / SAML",
    "Dedicated CSM",
    "SLA: 99.9% uptime",
    "Custom integrations via API"
  ]
}

package FreelancerStarter {
  tier: "entry"
  position: 1
  offering: FreelancerEdition
  description: "For platforms managing up to 25 independent contractors"
  pricing: {
    model: "tiered_subscription"
    basePrice: 79
    currency: "USD"
    paymentTerms: "monthly"
  }
  includes: [
    "Contractor onboarding (up to 25 users)",
    "Rate cards",
    "Timesheet approval",
    "Auto-invoicing"
  ]
}

# ── Pricing Models ──────────────────────────────────────────────────────────────

pricingModel PerSeatSubscription {
  type: "tiered_subscription"
  description: "Monthly or annual subscription priced per active user seat"
  discountPolicy: "Annual billing gives 20% discount vs. monthly"
}

pricingModel UsageBased {
  type: "usage_based"
  description: "Billing tied to number of active projects and API calls for Enterprise tier"
}

# ── Capabilities ───────────────────────────────────────────────────────────────

capability TimeAndExpenseCapture {
  description: "Mobile and web time tracking with expense logging, approval workflows, and audit trail"
  ownedBy: ProductEngineering
  maturity: {
    current: "expert"
  }
}

capability ProjectProfitabilityEngine {
  description: "Real-time margin calculation, budget monitoring, and scope-creep detection"
  ownedBy: ProductEngineering
  maturity: {
    current: "advanced"
  }
  dependsOn: TimeAndExpenseCapture
}

capability InvoicingAndBilling {
  description: "Draft-to-paid invoice lifecycle including partial billing and retainer management"
  ownedBy: ProductEngineering
  maturity: {
    current: "advanced"
  }
  dependsOn: TimeAndExpenseCapture
}

capability ClientCollaborationHub {
  description: "Project visibility portal: milestones, deliverable approvals, and payment gateway"
  ownedBy: CustomerSuccess
  maturity: {
    current: "intermediate"
  }
  dependsOn: InvoicingAndBilling
}

capability IntegrationLayer {
  description: "Bidirectional sync with Xero, QuickBooks, Salesforce, HubSpot, and Slack via REST API"
  ownedBy: Integrations
  maturity: {
    current: "advanced"
  }
}

capability AnalyticsAndReporting {
  description: "Configurable dashboards and scheduled reports for firm-level and project-level KPIs"
  ownedBy: DataPlatform
  maturity: {
    current: "intermediate"
  }
  dependsOn: ProjectProfitabilityEngine
}

# ── Systems ────────────────────────────────────────────────────────────────────

system CorePlatformAPI {
  description: "RESTful API serving all product surfaces: web app, mobile, client portal, and third-party integrations"
  type: "internal"
}

system DataWarehouse {
  description: "Redshift-based analytical data store for reporting and ML feature pipelines"
  type: "internal"
}

system AuthService {
  description: "OAuth 2.0 / SAML identity and access management service"
  type: "internal"
}

system StripePayments {
  description: "Third-party payment processing for invoice collection"
  type: "external"
}

# ── Teams ──────────────────────────────────────────────────────────────────────

team ProductEngineering {
  size: 28
  description: "Core platform development across web, mobile, and API"
}

team GrowthAndRevenue {
  size: 18
  description: "Sales, marketing, and revenue operations"
}

team CustomerSuccess {
  size: 12
  description: "Onboarding, adoption, and retention across all customer segments"
}

team DataPlatform {
  size: 6
  description: "Data engineering and analytics infrastructure"
}

team Integrations {
  size: 5
  description: "Partner integrations and API ecosystem"
}

# ── Roles ──────────────────────────────────────────────────────────────────────

role SeniorProductEngineer {
  description: "Leads feature delivery from design to production"
}

role AccountExecutive {
  description: "Manages outbound pipeline and closes mid-market deals"
}

role CustomerSuccessManager {
  description: "Owns post-sale relationship, onboarding, and renewal"
}

role SolutionsEngineer {
  description: "Technical pre-sales and implementation support"
}

# ── Processes ──────────────────────────────────────────────────────────────────

process CustomerOnboarding {
  description: "End-to-end process from contract signature to first live project"
  performedBy: CustomerSuccessManager
  measuredBy: TimeToOnboard
}

step ContractHandoff {
  description: "Sales-to-CS handoff: CRM deal marked Closed-Won, CS assigned"
  order: 1
  partOf: CustomerOnboarding
  performedBy: CustomerSuccessManager
}

step KickoffCall {
  description: "30-minute onboarding call to align scope, integrations, and launch date"
  order: 2
  partOf: CustomerOnboarding
  performedBy: CustomerSuccessManager
  dependsOn: ContractHandoff
}

step WorkspaceConfiguration {
  description: "CS configures team roles, project templates, and billing settings"
  order: 3
  partOf: CustomerOnboarding
  performedBy: CustomerSuccessManager
  dependsOn: KickoffCall
}

step IntegrationSetup {
  description: "Connect accounting and CRM systems via Integration Layer"
  order: 4
  partOf: CustomerOnboarding
  performedBy: SolutionsEngineer
  dependsOn: WorkspaceConfiguration
}

step TrainingAndHandover {
  description: "Product walkthrough session and self-serve resource pack delivered"
  order: 5
  partOf: CustomerOnboarding
  performedBy: CustomerSuccessManager
  dependsOn: IntegrationSetup
}

step GoLiveConfirmation {
  description: "Customer creates first live project; CS marks onboarding complete"
  order: 6
  partOf: CustomerOnboarding
  performedBy: CustomerSuccessManager
  dependsOn: TrainingAndHandover
}

process QuarterlyBusinessReview {
  description: "Regular strategic touchpoint with Enterprise customers to review outcomes and plan expansion"
  performedBy: CustomerSuccessManager
  measuredBy: NetRevenueRetention
}

step PrepareQBRDeck {
  description: "Pull utilisation, margin, and NRR data from Analytics; build slide deck"
  order: 1
  partOf: QuarterlyBusinessReview
  performedBy: CustomerSuccessManager
}

step DeliverQBRSession {
  description: "60-minute video call with economic buyer and project leads"
  order: 2
  partOf: QuarterlyBusinessReview
  performedBy: CustomerSuccessManager
  dependsOn: PrepareQBRDeck
}

step CaptureExpansionOpportunities {
  description: "Log any upgrade or cross-sell opportunities in CRM"
  order: 3
  partOf: QuarterlyBusinessReview
  performedBy: AccountExecutive
  dependsOn: DeliverQBRSession
}

# ── Customer Journey ────────────────────────────────────────────────────────────

journey MidMarketBuyerJourney {
  description: "Full lifecycle from awareness to advocacy for a mid-market consulting firm"
  targets: MidMarketConsultingFirms
  stages: [
    {
      name: "Awareness"
      touchpoints: ["Content marketing", "LinkedIn ads", "G2 reviews"]
      goal: "Prospect learns about Nexara and profitability use case"
    },
    {
      name: "Evaluation"
      touchpoints: ["Free trial", "Demo call", "Competitor comparison"]
      goal: "Prospect validates fit through 14-day trial and live demo"
    },
    {
      name: "Purchase"
      touchpoints: ["Proposal", "Legal review", "Contract signature"]
      goal: "Deal closed; Professional or Enterprise plan selected"
    },
    {
      name: "Onboarding"
      touchpoints: ["Kickoff call", "Configuration sessions", "Training"]
      goal: "Customer live within 7 days; first project created"
    },
    {
      name: "Adoption"
      touchpoints: ["In-app guidance", "Monthly check-in", "Feature releases"]
      goal: "70%+ team utilisation and first profitability report generated"
    },
    {
      name: "Expansion"
      touchpoints: ["QBR", "Upsell proposal", "CSM recommendation"]
      goal: "Customer upgrades seats or adds Client Portal module"
    },
    {
      name: "Advocacy"
      touchpoints: ["Case study", "G2 review request", "Referral programme"]
      goal: "Customer provides public reference and refers two new prospects"
    }
  ]
}
